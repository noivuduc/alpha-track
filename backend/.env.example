# backend/.env — Application configuration.
# Copy to .env and fill in values before starting the backend.

# ── App ───────────────────────────────────────────────────────────────────────
# development | staging | production
ENVIRONMENT=development

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# REQUIRED in production — startup will refuse to run with the default value.
SECRET_KEY=change-me-in-production

# ── Database ──────────────────────────────────────────────────────────────────
# Local development (postgres running on host):
DATABASE_URL=postgresql+asyncpg://alphatrack:changeme@localhost:5432/alphatrack

# Docker Compose (backend container to postgres container):
# DATABASE_URL=postgresql+asyncpg://alphatrack:changeme@postgres:5432/alphatrack

# ── Redis ─────────────────────────────────────────────────────────────────────
# Local development:
REDIS_URL=redis://:changeme@localhost:6379/0

# Docker Compose:
# REDIS_URL=redis://:changeme@redis:6379/0

# ── Market data providers ─────────────────────────────────────────────────────
# financialdatasets.ai — fundamentals, SEC filings, insider trades, earnings.
# Free tier available at https://financialdatasets.ai
# Leave blank to disable paid fundamentals (yfinance profile data is used instead).
PAID_PROVIDER_API_KEY=

# ── AI insights (optional) ────────────────────────────────────────────────────
# At least one key is required to use the Research / AI insights tab.
# Leave both blank to disable AI features entirely.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Tavily — news search for AI insights context.
# Free tier available at https://tavily.com
TAVILY_API_KEY=

# ── Advanced (optional overrides) ────────────────────────────────────────────
# DEBUG=false
# ACCESS_TOKEN_EXPIRE_MINUTES=60
# REFRESH_TOKEN_EXPIRE_DAYS=30
# FREE_PROVIDER_MAX_CONCURRENT=8
# CACHE_PRICE_TTL=900
# RISK_FREE_RATE=0.02
